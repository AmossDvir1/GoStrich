<?xml version="1.0" encoding="utf-8"?>
<!--
  Android data extraction rules (API 31+).
  Only backs up AsyncStorage (RKStorage). Auth tokens are excluded implicitly.
-->
<data-extraction-rules>
  <cloud-backup>
    <include domain="database" path="RKStorage" />
  </cloud-backup>
  <device-transfer>
    <include domain="database" path="RKStorage" />
  </device-transfer>
</data-extraction-rules>
