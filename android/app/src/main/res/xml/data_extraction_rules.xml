<?xml version="1.0" encoding="utf-8"?>
<!--
  Android data extraction rules (API 31+).
  Same include/exclude logic as backup_rules.xml but in the newer format.
  cloudBackup: what goes to Google Drive Auto Backup.
  deviceTransfer: what transfers during device-to-device migration.
-->
<data-extraction-rules>
  <cloud-backup>
    <include domain="database" path="RKStorage" />
    <exclude domain="sharedpref" path="RN.google.users.tokens" />
  </cloud-backup>
  <device-transfer>
    <include domain="database" path="RKStorage" />
    <exclude domain="sharedpref" path="RN.google.users.tokens" />
  </device-transfer>
</data-extraction-rules>
