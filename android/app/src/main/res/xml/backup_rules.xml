<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Auto Backup rules (API 23+).
  - Include AsyncStorage (RKStorage) so workout history survives reinstalls via Google Drive.
  - Exclude SecureStore (sharedprefs/RN.google.users.tokens) to avoid backing up auth tokens.
-->
<full-backup-content>
  <!-- Include AsyncStorage database -->
  <include domain="database" path="RKStorage" />
  <!-- Exclude SecureStore auth data -->
  <exclude domain="sharedpref" path="RN.google.users.tokens" />
</full-backup-content>
