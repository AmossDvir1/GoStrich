<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Auto Backup rules (API 23+).
  Only backs up AsyncStorage (RKStorage) so workout history survives reinstalls.
  SecureStore auth tokens are excluded implicitly — only explicitly included paths are backed up.
-->
<full-backup-content>
  <include domain="database" path="RKStorage" />
</full-backup-content>
